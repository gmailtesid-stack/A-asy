APP_NAME="E-ASY POS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.vercel.app

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── TiDB Cloud (MySQL Compatible) ───────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_DATABASE=sys
DB_USERNAME=jm7ETdoFCLactTB.root
DB_PASSWORD=kwRci29We1dRiVVW
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# ─── Cache & Session (file-based for Vercel) ─────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ─── Mail (Gmail / SMTP) ─────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@easy-pos.app
MAIL_FROM_NAME="${APP_NAME}"

# ─── Cloudinary ──────────────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_UPLOAD_PRESET=easy_pos_products
CLOUDINARY_NOTIFICATION_URL=

# ─── GitHub (untuk CI/CD info saja) ──────────────────────────────────
# Isi di Vercel Dashboard → Environment Variables
GITHUB_REPO=your-username/easy-pos
