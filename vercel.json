{
    "version": 2,
    "outputDirectory": "public",
    "crons": [
        {
            "path": "/api/process-queue",
            "schedule": "* * * * *"
        }
    ],
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2",
            "memory": 512,
            "maxDuration": 30
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images|fonts)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
