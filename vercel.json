{
    "version": 2,
    "regions": ["sin1"],
    "env": {
        "APP_NAME": "E-ASY POS",
        "APP_ENV": "production",
        "APP_KEY": "base64:cT3wN1uicXKYsFj04rvpanIYMkb8uQ4YJXThCFE0iIE=",
        "APP_DEBUG": "true",
        "APP_URL": "https://a-asy.vercel.app",
        "VERCEL": "1",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": "/tmp/database.sqlite"
    },
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3",
            "maxDuration": 60
        }
    },
    "rewrites": [
        {
            "src": "/(css|js|images|fonts|vendor|build|assets)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/ping",
            "dest": "/api/ping.php"
        },
        {
            "src": "/demo(.*)",
            "dest": "/public/images/demo.html"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
