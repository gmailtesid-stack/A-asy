{
    "version": 2,
    "regions": ["sin1"],
    "env": {
        "APP_NAME": "E-ASY POS",
        "APP_ENV": "production",
        "APP_KEY": "base64:cT3wN1uicXKYsFj04rvpanIYMkb8uQ4YJXThCFE0iIE=",
        "APP_DEBUG": "true",
        "APP_URL": "https://a-asy.vercel.app",
        "VERCEL": "1",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "CACHE_STORE": "array",
        "CACHE_PREFIX": "easypos_",
        "SESSION_DRIVER": "cookie",
        "SESSION_DOMAIN": "a-asy.vercel.app",
        "SESSION_SECURE_COOKIE": "true",
        "SESSION_ENCRYPT": "false",
        "SESSION_LIFETIME": "120",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "debug",
        "DB_CONNECTION": "sqlite",
        "FILESYSTEM_DISK": "local",
        "QUEUE_CONNECTION": "sync",
        "BROADCAST_CONNECTION": "log",
        "MAIL_MAILER": "log"
    },
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3",
            "memory": 1024,
            "maxDuration": 30
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|fonts|vendor|build|assets)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
