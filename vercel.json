{
    "version": 2,
    "outputDirectory": "public",
    "installCommand": "echo 'Skipping npm install'",
    "buildCommand": "echo 'Skipping build'",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "rewrites": [
        {
            "source": "/(css|js|images|fonts|build)/(.*)",
            "destination": "/public/$1/$2"
        },
        {
            "source": "/(robots.txt|favicon.ico)",
            "destination": "/public/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.php"
        }
    ]
}
