{
    "version": 2,
    "regions": ["sin1"],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": "database/database.sqlite"
    },
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2",
            "memory": 512,
            "maxDuration": 10
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/(css|js|images|fonts|vendor)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
